#!/usr/bin/env bash
#
# Custom pre-commit hook using prek (a fast, Rust-based pre-commit replacement).
# Symlinked from config/hooks/pre-commit by devenv/sync.py.
#
# Dev tools should be quiet by default — only errors deserve attention.
# prek's --quiet flag suppresses all output for passing/skipped hooks,
# so a clean commit produces just the status line below and nothing else.
# Failures still print full output so you can fix them.
#
echo "running prek (pre-commit)..."

HERE="$(cd "$(dirname "$0")" && pwd)"
PREK="$(git rev-parse --show-toplevel)/.venv/bin/prek"

if [ ! -x "$PREK" ]; then
    PREK="prek"
fi

exec "$PREK" hook-impl --quiet --hook-dir "$HERE" --hook-type=pre-commit -- "$@"
