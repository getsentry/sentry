config:
  rules:
  - attributes: {}
    fingerprint:
    - dogs-are-great
    - '{{ release }}'
    matchers:
    - - message
      - '*dogs*'
    text: message:"*dogs*" -> "dogs-are-great{{ release }}"
  version: 1
fingerprint:
- dogs-are-great
- '{{ release }}'
title: Yay, dogs!
variants:
  custom_fingerprint:
    matched_rule: message:"*dogs*" -> "dogs-are-great{{ release }}"
    type: custom_fingerprint
    values:
    - dogs-are-great
    - '{{ release }}'
  default:
    component:
      contributes: false
      hint: custom server fingerprint takes precedence
    type: component
