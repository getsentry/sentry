created: '2025-06-24T23:47:28.912057+00:00'
creator: sentry
source: tests/sentry/grouping/test_fingerprinting.py
---
config:
  rules:
  - attributes: {}
    fingerprint:
    - dogs-are-great
    - '{{ message }}'
    matchers:
    - - release
      - 2.*
    text: release:"2.*" -> "dogs-are-great{{ message }}"
  version: 1
fingerprint:
- dogs-are-great
- '{{ message }}'
title: Yay, dogs!
variants:
  custom_fingerprint:
    matched_rule: release:"2.*" -> "dogs-are-great{{ message }}"
    type: custom_fingerprint
    values:
    - dogs-are-great
    - Yay, dogs!
  default:
    component:
      contributes: false
      hint: custom server fingerprint takes precedence
    type: component
