#!/usr/bin/env python

from sentry.runner import configure

configure()

import argparse
import sys

import pydantic

from sentry.models.organization import Organization
from sentry.seer.agent.client import SeerAgentClient
from sentry.seer.agent.example_tools import SpellWordTool


def main(org_id: int) -> None:
    organization = Organization.objects.get(id=org_id)

    client = SeerAgentClient(
        organization,
        user=None,
        category_key="letter_counter",
        category_value=f"org-{organization.id}",
        intelligence_level="low",
        custom_tools=[SpellWordTool],
    )

    class LetterCount(pydantic.BaseModel):
        letter: str
        word: str
        count: int

    run_id = client.start_run(
        prompt="Count the number of R's in strawberry.",
        artifact_key="letter_count",
        artifact_schema=LetterCount,
    )

    state = client.get_run(run_id, blocking=True)
    result = state.get_artifact("letter_count", LetterCount)

    sys.stdout.write(f"> Started agent run {run_id}\n")

    sys.stdout.write(f"> Status: {state.status}\n")
    sys.stdout.write(f"> Artifacts: {list(state.get_artifacts().keys())}\n")
    sys.stdout.write(f"> Final message: {state.blocks[-1].message.content!r}\n")

    sys.stdout.write(f"> Result: {result}\n")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Demo SeerAgentClient with a simple prompt.")
    parser.add_argument(
        "org_id", nargs="?", default=1, type=int, help="Organization ID (default: 1)"
    )
    args = parser.parse_args()
    main(args.org_id)
