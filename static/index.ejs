            animation-timing-function: ease-out;
          }
          42.6% {
            stroke-dashoffset: 0;
            animation-timing-function: ease-out;
          }
          99.99% {
            stroke-dashoffset: -1150;
          }
          100% {
            stroke-dashoffset: 1150;
          }
        }
        @keyframes draw_g0_p0 {
